        const isEditor = inputEl.tagName !== 'TEXTAREA' && inputEl.isContentEditable;
        textarea.value = isEditor ? inputEl.innerText.replace(/\n$/, '') : inputEl.value;
        
        adjustHeight();
        
        if (window.visualViewport) {
            window.visualViewport.addEventListener('resize', positionModal);
        } else {
            window.addEventListener('resize', positionModal);
        }
        window.addEventListener('scroll', positionModal, true);
    }


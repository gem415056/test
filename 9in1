            document.getElementById('my-custom-info-display')?.remove();
            lastRenderedText = ''; currentInput = inputEl;
            
            counterBadge = document.createElement('div'); counterBadge.id = 'my-custom-info-display';
            textSpan = document.createElement('span'); textSpan.id = 'my-counter-text';
            counterBadge.appendChild(textSpan); 
            
            const colors = getThemeColors(inputEl);
            counterBadge.style.color = colors.text;

        function getThemeColors(el) {
            let bg = '#212121', current = el;
            while (current && current !== document.body) {
                const cBg = getComputedStyle(current).backgroundColor;
                if (cBg && cBg !== 'rgba(0, 0, 0, 0)' && cBg !== 'transparent') { bg = cBg; break; }
                current = current.parentElement;
            }
            const match = bg.match(/\d+/g);
            const isDark = match && match.length >= 3 ? (0.2126 * (+match[0]) + 0.7152 * (+match[1]) + 0.0722 * (+match[2])) < 128 : true;

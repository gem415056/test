        const fillCircle  = ring.querySelector('circle.fill');

        function isRerollBtn(el) {
            if (!el) return false;
            if (el.id === 'exp-reroll-btn') return true;
            return el.querySelector?.('svg path')?.getAttribute('d')?.startsWith('M3.8 12a8.2') ?? false;
        }

        function showRing(btn) {
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            const cx = size / 2, cy = size / 2, r = (size / 2) - 2;
            const circumference = 2 * Math.PI * r;

            svg.setAttribute('width', size); svg.setAttribute('height', size);
            svg.setAttribute('viewBox', `0 0 ${size} ${size}`);
            trackCircle.setAttribute('cx', cx); trackCircle.setAttribute('cy', cy); trackCircle.setAttribute('r', r);
            fillCircle.setAttribute('cx', cx); fillCircle.setAttribute('cy', cy); fillCircle.setAttribute('r', r);
            fillCircle.style.strokeDasharray  = circumference;
            fillCircle.style.strokeDashoffset = circumference;

            ring.style.left = `${rect.left}px`; ring.style.top  = `${rect.top}px`;
            ring.classList.add('active');

            requestAnimationFrame(() => {
                fillCircle.style.transition = `stroke-dashoffset ${HOLD_MS}ms linear`;
                fillCircle.style.strokeDashoffset = '0';
            });
        }

        function hideRing() {
            ring.classList.remove('active');
            fillCircle.style.transition = 'none';
            if (fillCircle.style.strokeDasharray) fillCircle.style.strokeDashoffset = fillCircle.style.strokeDasharray;
        }

        function cancel() {
            if (!holdTimer) return;
            clearTimeout(holdTimer);
            holdTimer = null;
            hideRing();
        }

        document.addEventListener('click', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            if (isConfirmed) { isConfirmed = false; return; }
            e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
        }, true);

        document.addEventListener('mousedown', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            showRing(btn);
            holdTimer = setTimeout(() => { hideRing(); isConfirmed = true; btn.click(); holdTimer = null; }, HOLD_MS);
        });

        document.addEventListener('mouseup', cancel);
        document.addEventListener('mouseleave', cancel);
        document.addEventListener('touchstart', (e) => {
            const btn = e.target.closest('button, [id="exp-reroll-btn"]');
            if (!isRerollBtn(btn)) return;
            e.preventDefault(); showRing(btn);
            holdTimer = setTimeout(() => { hideRing(); isConfirmed = true; btn.click(); holdTimer = null; }, HOLD_MS);
        }, { passive: false });
        document.addEventListener('touchend', cancel);
        document.addEventListener('touchcancel', cancel);
    }

    // ==========================================
    // 모듈 3: 더블클릭 수정
    // ==========================================
    function initDoubleClick() {
        function findMessageContainer(target) {
            let el = target;
            while (el && el !== document.body) {
                if (el.hasAttribute('data-message-group-id')) return el;
                el = el.parentElement;
            }
            return null;
        }

        function getReactProps(el) {
            const key = Object.keys(el).find(k => k.startsWith('__reactProps'));
            return key ? el[key] : null;
        }

        function firePointerClick(el) {
            const opts = { bubbles: true, cancelable: true };
            el.dispatchEvent(new PointerEvent('pointerover', opts));
            el.dispatchEvent(new PointerEvent('pointerenter', opts));
            el.dispatchEvent(new MouseEvent('mouseenter', opts));
            el.dispatchEvent(new PointerEvent('pointerdown', opts));
            el.dispatchEvent(new PointerEvent('pointerup', opts));
            el.click();
        }

        function tryReactEditClick(container) {
            const trigger = container.querySelector('div[aria-haspopup="menu"]');
            if (!trigger) return false;

            const style = document.createElement('style');
            style.id = 'igx-hide-dropdown';
            style.textContent = `[data-radix-popper-content-wrapper], [role="menu"] { opacity: 0 !important; pointer-events: none !important; }`;
            document.head.appendChild(style);

            firePointerClick(trigger);

            const start = Date.now();
            const timer = setInterval(() => {
                const item = Array.from(document.querySelectorAll('div[role="menuitem"]')).find(el => el.textContent.includes('수정'));
                if (item) {
                    clearInterval(timer);
                    const props = getReactProps(item);
                    if (props?.onSelect) props.onSelect();
                    else firePointerClick(item);
                    setTimeout(() => style.remove(), 100);
                } else if (Date.now() - start > 1500) {
                    clearInterval(timer);
                    style.remove();
                }
            }, 30);
            return true;
        }

        document.addEventListener('dblclick', (e) => {
            const container = findMessageContainer(e.target);
            if (!container) return;
            window.getSelection().removeAllRanges();
            tryReactEditClick(container);
        });
    }

    // ==========================================
    // 모듈 4: 오토스크롤
    // ==========================================
    function initAutoScroll() {
        const WAIT_TIME = 500;
        const TOP_THRESHOLD = 2;
        const AT_TOP_STABLE_LIMIT = 3;
        const MAX_STUCK_COUNT = 10;
        const BTN_ID = 'turbo-scroll-btn';
        const STYLE_ID = 'turbo-scroll-style';
        const MESSAGE_SELECTOR = 'div[data-message-group-id]';
        const sleep = ms => new Promise(r => setTimeout(r, ms));

        const iconUp = `<span style="font-size:15px;">△</span>`;
        const iconStop = `<span style="font-size:15px;">▲</span>`;

        let isRunning = false;

        function injectStyle() {
            if (document.getElementById(STYLE_ID)) return;
            const style = document.createElement('style');
            style.id = 'turbo-scroll-style';
            style.textContent = `
                #${BTN_ID}.tm-active { box-shadow: inset 0 0 0 2px hsl(var(--foreground, 0 0% 96%) / 0.65), 0 0 0 1px hsl(var(--foreground, 0 0% 96%) / 0.18); background: hsl(var(--accent, 0 0% 18%)) !important; }
                #${BTN_ID} span { color: inherit !important; fill: currentColor !important; }
            `;
            document.head.appendChild(style);
        }

        function updateIcon(btn, iconHtml) {
            btn.innerHTML = iconHtml;
        }

        function setButtonActive(btn, active) {
            if (!btn) return;
            btn.classList.toggle('tm-active', active);
            if (active) { updateIcon(btn, iconStop); btn.title = '로딩 중지'; btn.style.setProperty('transform', 'scale(0.96)', 'important'); } 
            else { updateIcon(btn, iconUp); btn.title = '과거 채팅 불러오기'; btn.style.setProperty('transform', 'none', 'important'); }
        }

        function isScrollableMessageContainer(el) {
            if (!el || el === document.body || el === document.documentElement) return false;
            const style = window.getComputedStyle(el);
            return (el.scrollHeight > el.clientHeight + 2 && el.clientHeight > 300 && ['auto', 'scroll'].includes(style.overflowY) && el.querySelectorAll(MESSAGE_SELECTOR).length > 0);
        }

        function findScrollContainer() {
            const messages = Array.from(document.querySelectorAll(MESSAGE_SELECTOR));
            if (messages.length > 0) {
                const candidates = new Set();
                const sampleMessages = [messages[0], messages[Math.floor(messages.length / 2)], messages[messages.length - 1]].filter(Boolean);
                for (const msg of sampleMessages) {
                    let current = msg.parentElement;
                    while (current && current !== document.body) { if (isScrollableMessageContainer(current)) candidates.add(current); current = current.parentElement; }
                }
                const sorted = Array.from(candidates).sort((a, b) => {
                    const aMsg = a.querySelectorAll(MESSAGE_SELECTOR).length, bMsg = b.querySelectorAll(MESSAGE_SELECTOR).length;
                    if (aMsg !== bMsg) return bMsg - aMsg;
                    return (b.scrollHeight - b.clientHeight) - (a.scrollHeight - a.clientHeight);
                });
                if (sorted[0]) return sorted[0];
            }
            const fallback = Array.from(document.querySelectorAll('div')).filter(isScrollableMessageContainer).sort((a, b) => {
                const aMsg = a.querySelectorAll(MESSAGE_SELECTOR).length, bMsg = b.querySelectorAll(MESSAGE_SELECTOR).length;
                if (aMsg !== bMsg) return bMsg - aMsg;
                return (b.scrollHeight - b.clientHeight) - (a.scrollHeight - a.clientHeight);
            });
            return fallback[0] || window;
        }

        function scrollToTop(target) {
            if (target === window) { window.scrollTo(0, 0); document.documentElement.scrollTop = 0; document.body.scrollTop = 0; return; }
            target.scrollTop = 0;
            try { target.scrollTo({ top: 0, behavior: 'auto' }); } catch {}
            try { target.dispatchEvent(new WheelEvent('wheel', { bubbles: true, cancelable: true, deltaY: -1500 })); } catch {}
        }

        function getSnapshot(target) {
            const messages = Array.from(document.querySelectorAll(MESSAGE_SELECTOR));
            return { count: messages.length, firstId: messages[0]?.getAttribute('data-message-group-id') || '', lastId: messages[messages.length - 1]?.getAttribute('data-message-group-id') || '', scrollHeight: target === window ? Math.max(document.documentElement.scrollHeight || 0, document.body.scrollHeight || 0) : target.scrollHeight || 0, scrollTop: target === window ? window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0 : target.scrollTop || 0 };
        }

        function getContentSignature(snapshot) { return snapshot ? [snapshot.count, snapshot.firstId, snapshot.lastId, snapshot.scrollHeight].join('|') : ''; }

        async function handleClick(e) {
            e.preventDefault(); e.stopPropagation();
            const btn = e.currentTarget;
            if (isRunning) { isRunning = false; setButtonActive(btn, false); return; }
            isRunning = true; setButtonActive(btn, true);
            let prevSignature = '', atTopStableCount = 0, stuckCount = 0;
            while (isRunning) {
                const target = findScrollContainer();
                scrollToTop(target);
                await sleep(WAIT_TIME);
                const snapshot = getSnapshot(target);
                const signature = getContentSignature(snapshot);
                if (snapshot.scrollTop <= TOP_THRESHOLD && signature === prevSignature) atTopStableCount++; else atTopStableCount = 0;
                if (signature === prevSignature) stuckCount++; else stuckCount = 0;
                prevSignature = signature;
                if (atTopStableCount >= AT_TOP_STABLE_LIMIT || stuckCount >= MAX_STUCK_COUNT) break;
            }
            isRunning = false; setButtonActive(btn, false);
        }

        document.addEventListener('keydown', e => { if (e.key === 'Escape') { isRunning = false; const btn = document.getElementById(BTN_ID); if (btn) setButtonActive(btn, false); } });
        injectStyle();

        setInterval(() => {
            const btn = document.getElementById(BTN_ID);
            if (btn && !btn.dataset.hooked) {
                btn.dataset.hooked = 'true';
                updateIcon(btn, iconUp);
                btn.onclick = handleClick;
                setButtonActive(btn, isRunning);
            }
        }, 1000);
    }

    // ==========================================
    // 모듈 5: 리롤 믹서
    // ==========================================
    function initRerollMixer() {
        const API_BASE = 'https://crack-api.wrtn.ai/crack-gen/v3';
        const SCRIPT_NS = 'crack-reroll-mixer';
        const MIXER_BUTTON_CLASS = `${SCRIPT_NS}-open-btn`;
        const MODAL_ID = `${SCRIPT_NS}-modal`;
        const MESSAGE_LIMIT = 200;
        const REFRESH_INTERVAL_MS = 1800;
        const DEBUG = false;

        let attachTimer = null;
        let busy = false;
        let lastUrlKey = getUrlKey();
        let activeEditorText = '';

        function log(...args) {
            if (DEBUG) console.log('[reroll-mixer]', ...args);
        }

        function getUrlKey() {
            return location.origin + location.pathname + location.search;
        }

        function toast(message, type = 'info', ms = 2200) {
            let box = document.getElementById(`${SCRIPT_NS}-toast`);
            if (!box) {
                box = document.createElement('div');
                box.id = `${SCRIPT_NS}-toast`;
                document.body.appendChild(box);
            }

            const item = document.createElement('div');
            item.className = `${SCRIPT_NS}-toast-item ${type}`;
            item.textContent = message;
            box.appendChild(item);

            setTimeout(() => {
                item.style.opacity = '0';
                item.style.transform = 'translateY(8px)';
                setTimeout(() => item.remove(), 240);
            }, ms);
        }

        function escapeHtml(value = '') {
            return String(value)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        function normalizeText(text = '') {
            return String(text).replace(/\s+/g, ' ').trim();
        }

        function stripSystemNote(text = '') {
            return normalizeText(
                String(text)
                    .replace(/^\s*\[\/\/\]:[^\n]*(?:\n|$)/gm, ' ')
                    .replace(/\[\/\/\]:\s*#\s*\([^)]+\)/g, ' ')
                    .replace(/```[\s\S]*?```/g, '[코드블록]')
                    .replace(/!\[[^\]]*\]\([^)]+\)/g, '[이미지]')
            );
        }

        function shortPreview(text = '', max = 120) {
            const cleaned = stripSystemNote(text);
            return cleaned.length > max ? cleaned.slice(0, max) + '…' : cleaned;
        }

        function getCookie(name) {
            const escaped = name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const match = document.cookie.match(new RegExp('(?:^|; )' + escaped + '=([^;]*)'));
            return match ? decodeURIComponent(match[1]) : null;
        }

        function getAccessToken() {
            return getCookie('access_token');
        }

        function getCommonHeaders() {
            const token = getAccessToken();
            const headers = {
                accept: 'application/json, text/plain, */*',
                platform: 'web',
                'wrtn-locale': 'ko-KR'
            };

            if (token) headers.authorization = `Bearer ${token}`;

            const wrtnId = getCookie('__w_id');
            if (wrtnId) headers['x-wrtn-id'] = wrtnId;

            const mixpanelId = getCookie('Mixpanel-Distinct-Id');
            if (mixpanelId) headers['mixpanel-distinct-id'] = mixpanelId;

            return headers;
        }

        function extractChatIdFromUrl(url = location.href) {
            const str = String(url || '');
            const patterns = [
                /\/episodes\/([a-f0-9]{24})(?:[/?#]|$)/i,
                /\/chats\/([a-f0-9]{24})(?:[/?#]|$)/i,
                /"chatId":"([a-f0-9]{24})"/i
            ];

            for (const pattern of patterns) {
                const match = str.match(pattern);
                if (match) return match[1];
            }

            return null;
        }

        function findChatId() {
            const fromUrl = extractChatIdFromUrl();
            if (fromUrl) return fromUrl;

            try {
                const html = document.documentElement.innerHTML;
                const fromHtml = extractChatIdFromUrl(html);
                if (fromHtml) return fromHtml;
            } catch (e) {}

            return null;
        }

        async function fetchAllMessages(chatId) {
            const url = `${API_BASE}/chats/${chatId}/messages?limit=${MESSAGE_LIMIT}`;
            const res = await fetch(url, {
                method: 'GET',
                credentials: 'include',
                headers: getCommonHeaders()
            });

            if (!res.ok) {
                throw new Error(`메시지 목록 로드 실패 (${res.status})`);
            }

            const json = await res.json();
            const messages = json?.data?.messages || json?.messages || [];
            return Array.isArray(messages) ? messages : [];
        }

        async function overwriteMessageOnServer(chatId, messageId, messageText) {
            const res = await fetch(`${API_BASE}/chats/${chatId}/messages/${messageId}`, {
                method: 'PATCH',
                credentials: 'include',
                headers: {
                    ...getCommonHeaders(),
                    'content-type': 'application/json'
                },
                body: JSON.stringify({ message: messageText })
            });

            if (!res.ok) {
                let body = '';
                try { body = await res.text(); } catch (e) {}
                throw new Error(`답변 덮어쓰기 실패 (${res.status}) ${body.slice(0, 180)}`);
            }

            return await res.json().catch(() => ({}));
        }

        function normalizeForVerify(text = '') {
            return String(text || '').replace(/\r\n/g, '\n').trim();
        }

        function saveOverwriteBackup({ chatId, messageId, beforeText, afterText, label }) {
            try {
                const key = `${SCRIPT_NS}:overwrite-backups`;
                const list = JSON.parse(localStorage.getItem(key) || '[]');
                list.unshift({
                    savedAt: new Date().toISOString(),
                    chatId,
                    messageId,
                    label,
                    beforeText,
                    afterText
                });
                localStorage.setItem(key, JSON.stringify(list.slice(0, 30)));
            } catch (e) {
                console.warn('[reroll-mixer] backup save failed:', e);
            }
        }

        function getMessageGroups() {
            return Array.from(document.querySelectorAll('div[data-message-group-id]'));
        }

        function getGroupMessageId(group) {
            return group?.getAttribute?.('data-message-group-id') || '';
        }

        function findCompareButtonInGroup(group) {
            if (!group) return null;
            const buttons = Array.from(group.querySelectorAll('button'));
            return buttons.find(btn => /답변\s*비교\s*\d+\s*\/\s*\d+/.test(normalizeText(btn.textContent || ''))) || null;
        }

        function parseCompareButton(group) {
            const btn = findCompareButtonInGroup(group);
            if (!btn) return null;

            const text = normalizeText(btn.textContent || '');
            const match = text.match(/답변\s*비교\s*(\d+)\s*\/\s*(\d+)/);
            if (!match) return null;

            return {
                button: btn,
                text,
                current: Number(match[1]),
                total: Number(match[2]),
                id: btn.id || ''
            };
        }

        function messageIdOf(msg) {
            return msg?._id || msg?.id || '';
        }

        function getMessageContent(msg) {
            return String(msg?.content || msg?.text || msg?.message || msg?.answer || '');
        }

        function isAssistantMessage(msg) {
            return String(msg?.role || '').toLowerCase() === 'assistant';
        }

        function isUserMessage(msg) {
            return String(msg?.role || '').toLowerCase() === 'user';
        }

        function getRerollFlag(msg) {
            const r = msg?.reroll;
            if (typeof r === 'boolean') return r;
            if (r && typeof r === 'object') return true;
            return false;
        }

        function buildMessageLookup(messages) {
            const idMap = new Map();
            const apiIndexMap = new Map();

            messages.forEach((msg, index) => {
                const id = messageIdOf(msg);
                if (!id) return;
                idMap.set(id, msg);
                apiIndexMap.set(id, index);
            });

            return { idMap, apiIndexMap };
        }

        function sortVariantsUiOrder(variants, apiIndexMap) {
            return [...variants].sort((a, b) => {
                const ai = apiIndexMap.get(messageIdOf(a)) ?? 0;
                const bi = apiIndexMap.get(messageIdOf(b)) ?? 0;
                return bi - ai;
            });
        }

        function findVariantBundleByDomGroup(group, messages, lookup) {
            const domMessageId = getGroupMessageId(group);
            const compareInfo = parseCompareButton(group);
            const anchor = lookup.idMap.get(domMessageId);

            if (!compareInfo || !anchor || !isAssistantMessage(anchor) || !anchor.parentTurnId) {
                return null;
            }

            const variants = messages.filter(msg =>
                isAssistantMessage(msg) &&
                msg.parentTurnId &&
                msg.parentTurnId === anchor.parentTurnId &&
                messageIdOf(msg)
            );

            if (variants.length <= 1) return null;

            const ordered = sortVariantsUiOrder(variants, lookup.apiIndexMap);
            const totalMatches = compareInfo.total === ordered.length;
            const currentIndex = compareInfo.current - 1;
            const userPrompt = messages.find(msg =>
                isUserMessage(msg) &&
                msg.turnId &&
                msg.turnId === anchor.parentTurnId
            );

            return {
                group,
                domMessageId,
                parentTurnId: anchor.parentTurnId,
                compareInfo,
                variants: ordered,
                totalMatches,
                currentIndex: totalMatches ? currentIndex : Math.max(0, ordered.findIndex(v => messageIdOf(v) === domMessageId)),
                userPrompt
            };
        }

        function splitIntoParagraphs(raw = '') {
            const text = String(raw || '')
                .replace(/\r\n/g, '\n')
                .trim();

            if (!text) return [];

            const blocks = [];
            let buffer = [];
            let inFence = false;

            const flushBuffer = () => {
                const value = buffer.join('\n').trim();
                if (value) blocks.push(value);
                buffer = [];
            };

            for (const line of text.split('\n')) {
                if (/^\s*```/.test(line)) {
                    inFence = !inFence;
                    buffer.push(line);
                    continue;
                }

                if (!inFence && /^\s*\[\/\/\]:/.test(line)) {
                    flushBuffer();
                    blocks.push(line.trim());
                    continue;
                }

                if (!inFence && line.trim() === '') {
                    flushBuffer();
                    continue;
                }

                buffer.push(line);
            }

            flushBuffer();

            return blocks
                .map(block => block.trim())
                .filter(Boolean);
        }

        function attachMixerButtons() {
            const currentUrlKey = getUrlKey();
            if (currentUrlKey !== lastUrlKey) {
                lastUrlKey = currentUrlKey;
                closeModal();
            }

            for (const group of getMessageGroups()) {
                const compareInfo = parseCompareButton(group);
                if (!compareInfo || compareInfo.total <= 1) continue;

                const compareBtn = compareInfo.button;
                if (!compareBtn || compareBtn.dataset.rerollMixerBound === 'true') continue;

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = `${MIXER_BUTTON_CLASS}`;
                btn.title = '리롤 답변 믹서 열기';
                btn.setAttribute('aria-label', '리롤 답변 믹서 열기');
                btn.innerHTML = '⧉';

                btn.addEventListener('click', async (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    await openMixerForGroup(group);
                });

                compareBtn.insertAdjacentElement('afterend', btn);
                compareBtn.dataset.rerollMixerBound = 'true';
            }
        }

        async function openMixerForGroup(group) {
            if (busy) return;

            const chatId = findChatId();
            if (!chatId) {
                alert('채팅 ID(chatId)를 찾을 수 없습니다.');
                return;
            }

            busy = true;
            toast('리롤 답변을 불러오는 중...', 'info', 1200);

            let messages;
            let lookup;
            let bundle;

            try {
                messages = await fetchAllMessages(chatId);
                lookup = buildMessageLookup(messages);
                bundle = findVariantBundleByDomGroup(group, messages, lookup);
            } catch (err) {
                console.error(err);
                alert('리롤 답변을 불러오지 못했습니다.');
                busy = false;
                return;
            }

            busy = false;

            if (!bundle) {
                alert('이 답변의 리롤 묶음을 찾지 못했습니다.\n답변 비교 버튼이 있는 메시지에서 다시 시도해 주세요.');
                return;
            }

            if (!bundle.totalMatches) {
                alert(`안전 확인 실패: 화면의 답변 수(${bundle.compareInfo.total})와 API 후보 수(${bundle.variants.length})가 다릅니다.`);
                return;
            }

            showMixerModal(bundle);
        }

        function showMixerModal(bundle) {
            closeModal();

            const overlay = document.createElement('div');
            overlay.id = MODAL_ID;
            overlay.className = 'crack-reroll-mixer-overlay';

            const total = bundle.variants.length;
            const current = Math.max(0, Math.min(bundle.currentIndex, total - 1));
            const defaultA = current;
            const defaultB = current > 0 ? current - 1 : Math.min(1, total - 1);

            const optionHtml = bundle.variants.map((msg, index) => {
                const preview = shortPreview(getMessageContent(msg), 54);
                const currentLabel = index === current ? ' · 현재' : '';
                return `<option value="${index}">답변 ${index + 1}${currentLabel} — ${escapeHtml(preview)}</option>`;
            }).join('');

            overlay.innerHTML = `
                <div class="crack-reroll-mixer-modal" role="dialog" aria-modal="true">
                    <div class="crm-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 12px; flex-shrink:0;">
                        <div>
                            <h3 style="margin: 0; font-size: 17px; font-weight: 700; color: #222 !important; display: flex; align-items: center; gap: 6px;">⧉ 리롤 믹서</h3>
                            <div class="crm-meta-sub" data-meta style="font-size: 12px; color: #666; margin-top: 4px; font-weight: 600;"></div>

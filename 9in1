                        <button class="crm-icon-btn" data-close style="background: none; border: none; font-size: 14px; cursor: pointer; padding: 4px 8px; border-radius: 6px; color: #666; transition: 0.2s; font-weight: bold;">✕</button>
                    </div>

                    <div class="crack-flex-ai-row" style="display: flex; gap: 12px; margin-bottom: 12px; flex-shrink: 0;">
                        <div class="fg" style="flex: 1; display: flex; flex-direction: column;">
                            <label style="font-size: 11px; font-weight: 600; margin-bottom: 4px; color: #555;">A 답변 선택</label>
                            <select data-select-a class="crm-select"></select>
                        </div>
                        <div class="fg" style="flex: 1; display: flex; flex-direction: column;">
                            <label style="font-size: 11px; font-weight: 600; margin-bottom: 4px; color: #555;">B 답변 선택</label>
                            <select data-select-b class="crm-select"></select>
                        </div>
                    </div>

                    <div class="crm-tabs-container">
                        <div class="crm-tabs">
                            <button class="crm-tab active" data-tab="a">답변 A</button>
                            <button class="crm-tab" data-tab="b">답변 B</button>
                            <button class="crm-tab" data-tab="edit">편집본</button>
                        </div>
                    </div>

                    <div class="crm-body" style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; min-height: 0;">

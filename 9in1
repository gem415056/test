                            <div class="pane-sub-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-shrink: 0;">
                                <span class="sub-meta-info" data-sub-meta-a style="font-size: 12px; color: #555; font-weight: 600;"></span>
                                <button type="button" class="crm-action-btn-sm" data-add-whole-a>전체 추가</button>
                            </div>
                            <div class="crm-paragraph-list" data-list-a style="flex: 1; overflow-y: auto; padding-right: 4px; display: flex; flex-direction: column; gap: 8px;"></div>
                        </section>

                        <section class="crm-pane-content" data-pane="b" style="display: none; flex-direction: column; flex: 1; min-height: 0;">
                            <div class="pane-sub-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-shrink: 0;">
                                <span class="sub-meta-info" data-sub-meta-b style="font-size: 12px; color: #555; font-weight: 600;"></span>
                                <button type="button" class="crm-action-btn-sm" data-add-whole-b>전체 추가</button>
                            </div>
                            <div class="crm-paragraph-list" data-list-b style="flex: 1; overflow-y: auto; padding-right: 4px; display: flex; flex-direction: column; gap: 8px;"></div>

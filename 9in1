    function positionModal() {
        const modal = document.getElementById('igx-shortcut-modal');
        const inputEl = getSafeMainInput();
        if (!modal || !inputEl) return;

        const container = inputEl.closest(".flex.w-full.flex-col.rounded-lg") || inputEl.closest(".flex.w-full.flex-col") || inputEl.parentElement;
        if (!container) return;

        const rect = container.getBoundingClientRect();
        const offset = 4.5; 
        
        modal.style.position = 'fixed';
        modal.style.left = (rect.left - offset) + 'px';
        modal.style.width = (rect.width + (offset * 2)) + 'px';
        modal.style.bottom = (window.innerHeight - rect.bottom - offset) + 'px';
    }

    function insertSymbolToModal(openSymbol, closeSymbol) {
        const textarea = document.getElementById('igx-shortcut-textarea');
        if (!textarea) return;

        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;

        const before = text.substring(0, start);
        const selected = text.substring(start, end);
        const after = text.substring(end);

        const newText = before + openSymbol + selected + closeSymbol + after;
        textarea.value = newText;

        const newCursorPos = start + openSymbol.length + selected.length;
        textarea.focus();
        textarea.setSelectionRange(newCursorPos, newCursorPos);

        textarea.dispatchEvent(new Event('input', { bubbles: true }));
    }

    function writeToTiptap(text) {
        const tiptap = getSafeMainInput();
        if (!tiptap) return;

        window.allowNativeFocus = true;
        window.isSyncingText = true;

        tiptap.focus();

        try {
            const range = document.createRange();
            range.selectNodeContents(tiptap);
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
        } catch (e) {
            window.getSelection().selectAllChildren(tiptap);
        }

        document.execCommand('delete', false, null);
        document.execCommand('insertText', false, text);

        setTimeout(() => {
            window.allowNativeFocus = false;
            window.isSyncingText = false;
            tiptap.blur();
        }, 100);
    }

